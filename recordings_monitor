function processData($country, $type)
{
    echo "Country: $country | Media: $type | Getting Records, Please Wait | ";
    $end = date("Y-m-d H:i:s");
    $start = date('Y-m-d H:i:s', strtotime('-1 days'));

    echo "$start -  $end | ";

    if ($type == 'TV') {
        $types = " 'TV','tv','Tv' ";
    } else {
        $types = " 'Radio','RADIO','radio' ";
    }


    $excludedStations = "'ANG', 'SUL', 'MBO', 'SAH', 'MBO', 'SAH', 'SEM', 'SHE', 'SKY', 'SYO', 'VUK', 'IFT', 'ING', 'MIN', 'MUB', 'MGO', 'MTU', 'NFM', 'NOS', 'NYO', 'QWE', 'R16'";


    $sq = "SELECT * FROM recordings 
           WHERE station_type IN ($types) 
           AND rpp_processed = 0 
           AND entrytime BETWEEN '$start' AND '$end' 
           AND country = '$country' 
           AND station_code NOT IN ($excludedStations)
           ORDER BY station_name ASC, stationdate DESC, stationtime ASC";

    echo "$sq\n";
    $q = MonitorDB()->query($sq) or die(MonitorDB()->error);
    echo "Unprocessed Records: " . $q->num_rows . "\n";
    $results = [];
    if ($q->num_rows > 0) {
        while ($row = $q->fetch_assoc()) {
            $results[] = $row;
        }
    }
    return $results;
}




function insertUnprocessed($arr)
{
    $check_url = 'https://s3.us-east-1.wasabisys.com/reelcloud.live/digital_recordings/';

