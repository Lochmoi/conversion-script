        $station_code = $row['station_code'];
        $station_type = $row['station_type'];
        $country = $row['country'];
        $fileurl = $row['fileurl'];
        $uploaded = $row['uploaded'];
        $moved = $row['moved'];
        $server_id = $row['server_id'];
        $processed = $row['processed'];

        $explode = explode('_', $filename);
        $timeExt = end($explode);
