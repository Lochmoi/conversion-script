}

function recordExists($filename, $stationdate)
{
    $sq = "SELECT id FROM recordings_monitor.recordings WHERE filename = '$filename' AND stationdate = '$stationdate' ";
    $q = MonitorDB()->query($sq) or die("Failed to Check record.\n" . MonitorDB()->error);
    if ($q->num_rows > 0) {
        return true;
    } else {
        return false;
    }
}

function does_url_exists($url)
{
    $ch = curl_init($url);
    curl_setopt($ch, CURLOPT_NOBODY, true);
    curl_exec($ch);
    $code = curl_getinfo($ch, CURLINFO_HTTP_CODE);

    if ($code == 200) {
        $status = true;
    } else {
        $status = false;
    }
    curl_close($ch);
    return $status;
}

