        }

        $checkfile = $check_url . $monyear . $station_code . '/' . $dpath . '/' . $filename;
        //echo "$checkfile\n";

        echo "$count/$size | $station_name | $station_type | $filename | $filetype |  $stationdate | $stationtime | ";

